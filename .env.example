TELEGRAM_BOT_TOKEN=replace_with_your_telegram_bot_token
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
ALT_CLOUD_BASE_URL=
ALT_CLOUD_API_KEY=
ALT_CLOUD_MODEL=
SEARXNG_URL=http://localhost:8081
ATHENA_LOCATION=
ATHENA_TIMEZONE=UTC
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
# Ollama request timeout in seconds (default: 120)
OLLAMA_TIMEOUT=120
# How long Ollama keeps the model loaded in memory (default: 30m)
OLLAMA_KEEP_ALIVE=30m
# Max tokens for Ollama completions (default: 256)
OLLAMA_NUM_PREDICT=256
VOICE_REPLIES_ENABLED=false
PIPER_EXECUTABLE=piper
PIPER_MODEL_PATH=
PIPER_VOICES=
NOMINATIM_USER_AGENT=athena-ai/1.0
WHISPER_MODEL=base
ATHENA_DATABASE_PATH=athena/data/athena.db
LOG_LEVEL=INFO
# File where every model prompt+response is logged for observability (empty = disabled)
PROMPT_LOG_PATH=athena/data/prompts.log
# Max conversation turns to fetch for context window (default: 12)
HISTORY_WINDOW=12
# Max total characters of conversation history sent to the model (default: 1500)
HISTORY_MAX_CHARS=1500
# Seconds between proactive checks for upcoming tasks/reminders (default: 600 = 10 min)
REMINDER_CHECK_INTERVAL=600
